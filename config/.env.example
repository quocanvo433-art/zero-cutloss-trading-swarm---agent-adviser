# ==========================================
# ZERO CUTLOSS EMPIRE — .env.example
# ==========================================
# Copy this file to config/.env and fill in the actual values.
# This file is safe to commit to Git (contains no secrets).
# ==========================================

# ── 1. CORE INFRASTRUCTURE ────────────────────────────────────────────────
# Local run (outside Docker): redis://localhost:6379
# Docker run:                redis://:your_password@redis:6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=generate_64_char_random_string_here
CHROMA_URL=http://localhost:8001
CHROME_DEBUG_PORT=9222

# ── 2. SECURITY & SECRETS ─────────────────────────────────────────────────
TELEGRAM_TOTP_SECRET=BASE32_STRING_FROM_GENERATOR
TELEGRAM_CHALLENGE_SECRET=BASE64_STRING_FROM_GENERATOR
TELEGRAM_CRITICAL_CONFIRM=True
# HMAC Secret for DPO Pairs (create: python -c "import secrets; print(secrets.token_hex(32))")
PAIRS_SIGNING_SECRET=generate_64_char_random_string_here
# HMAC Secret for Immunity Core (FIM)
IMMUNITY_HMAC_SECRET=generate_64_char_random_string_here
# Grafana Admin Password
GRAFANA_PASSWORD=generate_strong_password_here

# ── 3. TELEGRAM BOT & SCRAPER ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id
TELEGRAM_GROUP_ID_COMMON=-100_your_common_group_id
TELEGRAM_GROUP_ID_ELITE=-100_your_elite_group_id
# Used to crawl Telegram channels (from my.telegram.org)
TELEGRAM_API_ID=your_api_id_number
TELEGRAM_API_HASH=your_api_hash_string
TELEGRAM_PHONE=+84_your_phone_number

# ── 4. BRAIN INTELLIGENCE (LLM APIs) ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_account_1
GEMINI_API_KEY_2=your_gemini_key_account_2
DEEPSEEK_API_KEY=your_deepseek_key
SILICONFLOW_API_KEY=your_siliconflow_key
GROQ_API_KEY=your_groq_key

# ── 5. MARKET API (Trading) ────────────────────────────────────────────────
# Binance: Read + Futures ONLY. Withdrawals MUST be disabled.
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
# Bybit (optional)
BYBIT_API_KEY=your_bybit_api_key
BYBIT_SECRET_KEY=your_bybit_secret_key

# ── 6. SENTIMENT ANALYSIS - Agent 03 ───────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ZeroCutlossBot/1.0
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
LUNARCRUSH_API_KEY=your_lunarcrush_key
YOUTUBE_API_KEY=your_youtube_data_api_key
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ── 7. MONEY FLOW & ECONOMICS - Agent 10 ──────────────────────────────────
FRED_API_KEY=your_fred_api_key
EIA_API_KEY=your_eia_open_data_api_key
DUNE_API_KEY=your_dune_analytics_api_key
# Fill after saving query on dune.com (URL: dune.com/queries/XXXXXXX)
DUNE_QUERY_BTC_NETFLOW=your_query_id
DUNE_QUERY_BTC_WHALE=your_query_id
DUNE_QUERY_ETH_FLOW=your_query_id
UNUSUAL_WHALES_KEY=your_unusual_whales_key
NANSEN_KEY=your_nansen_key
GLASSNODE_KEY=your_glassnode_key

# ── 8. OPERATIONAL SETTINGS ────────────────────────────────────────────────
WARMUP_N=20
MIN_SIGNALS=3
DEFAULT_SECURITY_LEVEL=NORMAL
